# ── Create .gitignore ────────────────────────────────────────────────────────
gitignore = """
# Data files — too large or sensitive for git


# Python
__pycache__/
*.py[cod]
*.pyo
.env
.venv
venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
"""

with open(".gitignore", "w") as f:
    f.write(gitignore.strip())
print("Created: .gitignore")